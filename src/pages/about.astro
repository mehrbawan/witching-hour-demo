---
import Layout from "../layouts/Layout.astro";
import StaffCard from "../components/StaffCard.astro";
---

<Layout>
  <main class="relative overflow-clip">
    <div
      class="starfield absolute inset-0 z-[10] overflow-hidden pointer-events-none opacity-70"
      id="starfield"
    >
    </div>

    <!-- Header -->
    <header
      class="relative flex flex-col items-center justify-center md:justify-start gap-5 w-full pt-30 pb-16 px-10 text-center font-sans"
    >
      <div
        class=" blob z-0 w-75 h-75 rounded-full absolute bg-medium-purple blur-[100px] top-0 left-1/2 md:left-auto right-0 top-0 md:visible opacity-30 md:opacity-70"
      >
      </div>

      <span
        class="kicker font-display text-xs tracking-[0.3em] uppercase text-mint"
        >Enter the Hour</span
      >
      <h1 class="font-display text-4xl md:text-6xl text-white">
        About <span class="text-gold">Witching Hour</span>
      </h1>
      <span class="text-stone max-w-2xl"
        >Insert a blurb here, Nicholas write something please.</span
      >
    </header>

    <!-- Our Story -->
    <section class="relative w-full flex flex-col md:flex-row items-center justify-center md:-mt-10 lg:-mt-30 py-10">
      <div
        class=" blob z-0 w-75 h-75 rounded-full absolute bg-mint blur-[100px] top-20 md:-left-20 lg:left-0  md:visible opacity-70"
      >
      </div>
      <img src="/mage_transparent.png" class="z-10 md:w-1/3 md:-translate-y-20 md:-translate-x-10 md:scale-120">

      <div
        class="flex flex-col gap-4 items-center justify-center text-center py-10 px-20 md:p-0"
      >
        <h2 class="font-display text-2xl md:text-4xl text-cream">
          Section Heading Placeholder
        </h2>
        <p class="text-stone text-sm md:text-base">
          Lorem ipsum, dolor sit amet consectetur adipisicing elit. Omnis
          laborum excepturi nostrum cum, eos debitis! Quia aut, alias quisquam
          autem consequuntur repellat, vel repellendus magnam ipsum aliquam
          veniam fugiat expedita itaque cum? Corporis, atque ipsam
          exercitationem in nam nesciunt vero.
        </p>
        <p class="text-stone text-sm md:text-base">
          Lorem, ipsum dolor sit amet consectetur adipisicing elit. Tenetur
          ullam doloremque quibusdam atque recusandae et neque. Dolorem
          inventore voluptatum impedit, error facere rem asperiores architecto,
          nesciunt est ad non obcaecati itaque nobis, beatae eius odio aliquid
          veritatis esse doloribus illo?
        </p>
      </div>
      <img src="/lady_transparent.png" class="md:w-1/3 md:translate-y-30 md:translate-x-10 lg:translate-x-0 md:scale-120">

    </section>

    <!-- Team -->
    <section class="relative w-full px-10 pb-24">
      <div
        class=" blob z-0 w-100 h-100 rounded-full absolute bg-gold blur-[100px] -right-20 -bottom-30 md:visible opacity-70"
      >
      </div>
      <div class="max-w-5xl mx-auto flex flex-col gap-10 items-center">
        <div class="flex flex-col items-center gap-3 text-center">
          <h2 class="font-display text-2xl md:text-4xl text-cream">
            Meet the Staff
          </h2>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 w-full"
        >

        <StaffCard name="Name Placeholder" role="Role Placeholder" bio="A short bio placeholder sentence." />
        <StaffCard name="Name Placeholder" role="Role Placeholder" bio="A short bio placeholder sentence." />
        <StaffCard name="Name Placeholder" role="Role Placeholder" bio="A short bio placeholder sentence." />
        </div>
      </div>
    </section>
  </main>
</Layout>
<script>
  const field = document.getElementById("starfield");
  if (field) {
    const STAR_COUNT = 80;
    let html = "";
    for (let i = 0; i < STAR_COUNT; i++) {
      const x = Math.random() * 100;
      const y = Math.random() * 70;
      const s = (Math.random() * 2 + 1).toFixed(2);
      const o = (Math.random() * 1 + 0.4).toFixed(2);
      html += `<span class="star" style="left:${x}%;top:${y}%;width:${s}px;height:${s}px;opacity:${o}"></span>`;
    }
    field.innerHTML = html;
  }
</script>
